# Copy to .env next to docker-compose.yml:
#   cp env.example .env
#
# FRONTEND_URL = exact URL users open in the browser (no trailing slash).
# Examples: http://13.48.x.x  or  https://app.yourdomain.com

POSTGRES_PASSWORD=change-me-long-random-string
JWT_SECRET=change-me-another-long-random-string
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GOOGLE_CLIENT_ID=

# Optional email (password reset, etc.)
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=

# CACHE_TTL=86400
