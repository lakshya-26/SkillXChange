# Copy to .env next to docker-compose.yml:
#   cp env.example .env
#
# FRONTEND_URL = public URL of your SPA (Netlify, etc.) — links in emails, OAuth.
# EC2 nginx only exposes /api and /socket.io (no frontend build in Docker).
#
# AWS: Security group must allow inbound TCP 80 from 0.0.0.0/0 (or Cloudflare) for the API.
#
# After clone: git submodule update --init --recursive (repo root).

POSTGRES_PASSWORD=change-me-long-random-string
JWT_SECRET=change-me-another-long-random-string
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GOOGLE_CLIENT_ID=

# Optional email (password reset, etc.)
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=

# CACHE_TTL=86400
